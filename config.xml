<?xml version='1.0' encoding='utf-8'?>
<widget id="com.astronomy.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>星际探索</name>
    <description>
        一个专业的天体物理学知识平台，涵盖恒星、黑洞、宇宙学、暗物质、引力波等前沿天文学内容。探索无垠宇宙，发现科学奥秘。
    </description>
    <author email="admin@astronomy.app" href="https://astronomy.app">
        星际探索团队
    </author>
    <content src="index.html" />
    <plugin name="cordova-plugin-whitelist" spec="1" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
        <icon src="icon-192.png" density="mdpi" />
        <icon src="icon-512.png" density="xxxhdpi" />
        <splash src="splash.png" density="port-mdpi" />
    </platform>
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
    </platform>
    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    <preference name="BackgroundColor" value="0x0a0e1b" />
    <preference name="SplashScreen" value="screen" />
    <preference name="SplashScreenDelay" value="3000" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="ShowSplashScreenSpinner" value="true" />
</widget>
